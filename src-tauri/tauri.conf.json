{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TransNovel",
  "mainBinaryName": "TransNovel",
  "version": "0.1.1",
  "identifier": "com.azyu.noveltr",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://generativelanguage.googleapis.com http://localhost:8080; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "TransNovel"
    },
    "category": "Utility",
    "shortDescription": "AI-powered Japanese web novel translator",
    "longDescription": "A desktop application for translating Japanese web novels to Korean using AI (Gemini/Claude)"
  }
}
